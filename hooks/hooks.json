{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "out=$(npx -y rafads hook-context 2>/dev/null) && [ -n \"$out\" ] && printf '%s\\n' \"$out\" || cat \"${CLAUDE_PLUGIN_ROOT}/hooks/session-context.md\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
